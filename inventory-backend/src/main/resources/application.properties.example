# application.properties.example
# Copy this file, rename to application.properties, and fill in your real values.


# Database
spring.datasource.url=jdbc:postgresql://localhost:5432/kkjewellers
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD
spring.jpa.hibernate.ddl-auto=update

# Jackson
spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.mapper.require-handlers-for-java8-times=false

# Gold API (get your key from https://www.goldapi.io)
goldapi.key=YOUR_GOLDAPI_KEY_HERE

# Silver API (if applicable)
silverapi.key=YOUR_SILVERAPI_KEY_HERE

# Server port (optional, default is 8080)
server.port=8080